# Microflex CRM — environment template
# Copy to apps/web/.env.local for local dev. Production secrets live in Secret Manager.

# Front-end (Vite — must be prefixed with VITE_)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=microflex-crm-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=microflex-crm-dev
VITE_FIREBASE_STORAGE_BUCKET=microflex-crm-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: enable emulator mode locally
VITE_USE_EMULATORS=true

# Workspace SSO domain restriction (the only domain allowed to sign in to internal CRM)
VITE_AUTH_HOSTED_DOMAIN=microflexfilm.com

# Functions — DO NOT put real secrets here. Use Secret Manager:
#   gcloud secrets create google-oauth-client-secret --data-file=...
#   gcloud secrets create slack-webhook-prod-floor   --data-file=...
#   gcloud secrets create slack-webhook-shipping     --data-file=...
