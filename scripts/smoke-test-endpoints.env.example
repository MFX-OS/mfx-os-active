# Copy to .env.smoke (gitignored) and fill in real values.
# Load before running: `set -a; . ./.env.smoke; set +a; npm run test:smoke`
# Or on Windows PowerShell: Get-Content .env.smoke | ForEach-Object { if ($_ -match '^([^=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }; npm run test:smoke

# ── Required ──
FIREBASE_API_KEY=                  # Web API key from Firebase Console > Project Settings
MFX_TEST_PORTAL_EMAIL=             # Client email tied to MFX_TEST_QUOTE_ID
MFX_TEST_PORTAL_PASSWORD=          # Or set MFX_TEST_PORTAL_ID_TOKEN instead
MFX_TEST_STAFF_EMAIL=              # @microflexfilm.com email
MFX_TEST_STAFF_PASSWORD=           # Or set MFX_TEST_STAFF_ID_TOKEN instead
MFX_TEST_QUOTE_ID=                 # Real quote doc id (any status, but client must match)
MFX_TEST_SO_ID=                    # Real salesOrders doc id (will get driveLink updated)

# ── Optional ──
MFX_BASE_URL=https://mfx-2026.web.app
MFX_TEST_SO_NUM=
MFX_TEST_SO_COMPANY=SMOKE TEST

# Skip individual tests by setting these to 1
SKIP_UPLOAD=
SKIP_FOLDER=
SKIP_SO_PDF=
