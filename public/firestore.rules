rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users full access to all MFX collections
    function isAuthenticated() {
      return request.auth != null;
    }

    // Job Tickets
    match /jobTickets/{ticketId} {
      allow read, write: if isAuthenticated();
    }

    // Customers
    match /customers/{customerId} {
      allow read, write: if isAuthenticated();
    }

    // Quotes
    match /quotes/{quoteId} {
      allow read, write: if isAuthenticated();
    }

    // Sales Orders
    match /salesOrders/{orderId} {
      allow read, write: if isAuthenticated();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }

    // Requests
    match /requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, write: if isAuthenticated();
    }

    // Activity feed
    match /activity/{activityId} {
      allow read, write: if isAuthenticated();
    }

    // Microfeed
    match /microfeed/{feedId} {
      allow read, write: if isAuthenticated();
    }

    // Users / Presence
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Projects
    match /projects/{projectId} {
      allow read, write: if isAuthenticated();
    }

    // Collaboration (notes, threads)
    match /collaboration/{docPath=**} {
      allow read, write: if isAuthenticated();
    }

    // Chat
    match /chat/{chatId} {
      allow read, write: if isAuthenticated();
    }

    // Threads / Discussions / DMs
    match /threads/{threadId} {
      allow read, write: if isAuthenticated();
    }
    match /discussions/{discussionId} {
      allow read, write: if isAuthenticated();
    }
    match /dms/{dmId} {
      allow read, write: if isAuthenticated();
    }

    // Support
    match /support/{supportId} {
      allow read, write: if isAuthenticated();
    }

    // Blueprints
    match /blueprints/{blueprintId} {
      allow read, write: if isAuthenticated();
    }

    // Job Passports
    match /jobPassports/{passportId} {
      allow read, write: if isAuthenticated();
    }
  }
}
