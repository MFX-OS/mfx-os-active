{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "target": "os",
      "public": "public",
      "predeploy": [
        "npm --prefix . run build"
      ],
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "**/customers-data.json",
        "**/job-tickets-data.json",
        "**/*.bak",
        "**/*.backup",
        "**/*.rules",
        "**/seed-*.json",
        "**/dump-*.json",
        "**/*-data.json"
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "X-Content-Type-Options",
              "value": "nosniff"
            },
            {
              "key": "X-Frame-Options",
              "value": "SAMEORIGIN"
            },
            {
              "key": "Referrer-Policy",
              "value": "strict-origin-when-cross-origin"
            },
            {
              "key": "Permissions-Policy",
              "value": "camera=(), microphone=(), geolocation=()"
            },
            {
              "key": "Content-Security-Policy",
              "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://apis.google.com https://accounts.google.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://browser.sentry-cdn.com https://*.firebaseio.com https://*.googleapis.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://*.gstatic.com https://*.firebaseio.com https://*.cloudfunctions.net https://*.run.app https://cdnjs.cloudflare.com https://browser.sentry-cdn.com https://*.sentry.io wss://*.firebaseio.com https://*.firebasestorage.app https://firebasestorage.googleapis.com; frame-src 'self' https://accounts.google.com https://apis.google.com https://docs.google.com https://drive.google.com https://mfx-2026.web.app https://os.microflexfilm.com; object-src 'none'; base-uri 'self'"
            }
          ]
        },
        {
          "source": "ceo-dash.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            },
            {
              "key": "Content-Security-Policy",
              "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://apis.google.com https://accounts.google.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com https://*.firebaseio.com https://*.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://*.gstatic.com https://*.firebaseio.com https://*.cloudfunctions.net https://*.run.app https://browser.sentry-cdn.com https://*.sentry.io wss://*.firebaseio.com https://accounts.google.com; frame-src 'self' https://accounts.google.com https://mfx-2026.web.app https://os.microflexfilm.com; object-src 'none'; base-uri 'self'"
            }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "js/mfx-bundle.*.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/portal",
          "destination": "/portal.html"
        },
        {
          "source": "/portal/**",
          "destination": "/portal.html"
        },
        {
          "source": "/api/portalUploadToDrive",
          "function": {
            "functionId": "portalUploadToDrive",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/backfillPortalEmails",
          "function": {
            "functionId": "backfillPortalEmails",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/uploadToDrive",
          "function": {
            "functionId": "uploadToDrive",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/getClientFolder",
          "function": {
            "functionId": "getClientFolder",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/getPortalUploadFolder",
          "function": {
            "functionId": "getPortalUploadFolder",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/driveAccessDiagnostic",
          "function": {
            "functionId": "driveAccessDiagnostic",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/nextSequence",
          "function": {
            "functionId": "nextSequence",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/provisionPPDWorkspace",
          "function": {
            "functionId": "provisionPPDWorkspace",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/ingestSharedInbox",
          "function": {
            "functionId": "ingestSharedInbox",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/ceoApprove",
          "function": {
            "functionId": "ceoApprove",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/transitionStatus",
          "function": {
            "functionId": "transitionStatus",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/saveQuotePDF",
          "function": {
            "functionId": "saveQuotePDF",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/saveSalesOrderPDF",
          "function": {
            "functionId": "saveSalesOrderPDF",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/processVPOApproval",
          "function": {
            "functionId": "processVPOApproval",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/checkOverdueVPOs",
          "function": {
            "functionId": "checkOverdueVPOs",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/createPassport",
          "function": {
            "functionId": "createPassport",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/ppdHealthCheck",
          "function": {
            "functionId": "ppdHealthCheck",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/scheduledInboxIngest",
          "function": {
            "functionId": "scheduledInboxIngest",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/getControlledRecordsRegister",
          "function": {
            "functionId": "getControlledRecordsRegister",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/assembleJobPacket",
          "function": {
            "functionId": "assembleJobPacket",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/agents/run",
          "function": {
            "functionId": "aiRunAgent",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/agents/approve",
          "function": {
            "functionId": "aiApproveAction",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/agents/reject",
          "function": {
            "functionId": "aiRejectAction",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/agents/recommendations",
          "function": {
            "functionId": "aiGetRecommendations",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/agents/health",
          "function": {
            "functionId": "aiGetHealth",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "finance",
      "public": "public-finance",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "**/customers-data.json",
        "**/job-tickets-data.json",
        "**/*.bak",
        "**/*.backup",
        "**/*.rules",
        "**/seed-*.json",
        "**/dump-*.json",
        "**/*-data.json"
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "X-Content-Type-Options",
              "value": "nosniff"
            },
            {
              "key": "X-Frame-Options",
              "value": "SAMEORIGIN"
            },
            {
              "key": "Referrer-Policy",
              "value": "strict-origin-when-cross-origin"
            },
            {
              "key": "Permissions-Policy",
              "value": "camera=(), microphone=(), geolocation=()"
            },
            {
              "key": "Content-Security-Policy",
              "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://apis.google.com https://accounts.google.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://browser.sentry-cdn.com https://*.firebaseio.com https://*.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://*.gstatic.com https://*.firebaseio.com https://*.cloudfunctions.net https://*.run.app https://cdnjs.cloudflare.com https://browser.sentry-cdn.com https://*.sentry.io wss://*.firebaseio.com; frame-src 'self' https://accounts.google.com https://apis.google.com https://mfx-2026.web.app https://os.microflexfilm.com; object-src 'none'; base-uri 'self'"
            }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
